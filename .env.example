# =============================================================================
# FreshMart — Environment Variables
# =============================================================================
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# On Vercel: add each variable in Project → Settings → Environment Variables.
# Never commit `.env`, `.env.local`, or real secrets to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database — Neon PostgreSQL
# -----------------------------------------------------------------------------
# DATABASE_URL → pooled connection (use in app runtime + Prisma Client)
# DIRECT_URL   → direct connection (required for `prisma migrate`)
#
# Neon dashboard: Project → Connection Details
#   - "Pooled connection"  → DATABASE_URL
#   - "Direct connection"    → DIRECT_URL
#
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Clerk — Authentication
# -----------------------------------------------------------------------------
# Dashboard: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret (Clerk → Webhooks → endpoint → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Route URLs (must match App Router paths in src/app/(auth)/)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Optional: restrict sign-up to specific domains
# CLERK_ALLOWED_EMAIL_DOMAINS=freshmart.com,clientstore.com

# -----------------------------------------------------------------------------
# Admin access
# -----------------------------------------------------------------------------
# Platform developer — SUPER_ADMIN (branding + full control)
SUPER_ADMIN_EMAILS=developer@example.com

# Store owner — ADMIN (catalog, orders, customers — no branding)
ADMIN_EMAILS=owner@example.com

# -----------------------------------------------------------------------------
# Email — Resend (order notifications)
# -----------------------------------------------------------------------------
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives new-order admin alerts (can match ADMIN_EMAILS)
ADMIN_EMAIL=owner@example.com

# Verified sender (required in production after domain verification in Resend)
# RESEND_FROM_EMAIL=Storefront <orders@yourdomain.com>

# -----------------------------------------------------------------------------
# Cloudinary — Product images
# -----------------------------------------------------------------------------
# Dashboard: https://console.cloudinary.com → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret

# Public cloud name (safe for client; used if you add client-side upload later)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Optional: folder prefix for all product uploads
CLOUDINARY_FOLDER=freshmart/products

# Optional: unsigned upload preset (only if you enable unsigned uploads)
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=freshmart_unsigned

# -----------------------------------------------------------------------------
# Razorpay — Payments (India)
# -----------------------------------------------------------------------------
# Dashboard: https://dashboard.razorpay.com → Settings → API Keys
# Use Test Mode keys for development.

# Public key (safe for browser checkout modal)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Server-only keys (never expose to client)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Webhook secret (Razorpay → Webhooks → endpoint → Secret)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Currency for orders (default INR)
RAZORPAY_CURRENCY=INR
